# ISDS testovací přístup — zkopíruj tento soubor jako "isds.env" a vyplň.
# Spuštění: npm run isds-test   (nebo: node scripts/isds-test.js)
# Soubor isds.env je v .gitignore, takže se necommituje.

ISDS_ENV=test

# Přihlašovací údaje TESTOVACÍ (PFO) schránky:
ISDS_LOGIN=
ISDS_PASSWORD=

# Volitelné — ověření schránky podle IČO (IČO tvé testovací PFO schránky):
ISDS_FIND_IC=

# Volitelné — odeslání testovací zprávy do této schránky (dbID testovací OVM schránky):
ISDS_SEND_TO=

# Volitelné přepisy endpointu (nech prázdné, pokud výchozí czebox funguje):
# ISDS_HOST=https://www.czebox.cz
# ISDS_BASEPATH=/DS
