{
  "name": "lexiseditor",
  "productName": "LexisEditor",
  "version": "3.4.1",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Zdenekdi/LexisEditor.git"
  },
  "description": "LexisEditor: AI-native náhrada MS Word pro advokáty. Stabilní právnické číslování, automatická anonymizace a hluboká integrace lokální AI (Ollama). Práce se strukturovanými daty pro přesnou rešerši a stylizaci dokumentů. Soukromí na prvním místě, 100% offline běh. Profesionální legal-tech pro Windows, Mac i Linux.",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "npm version patch --no-git-tag-version && electron-builder",
    "test": "jest",
    "test:e2e": "playwright test",
    "test:all": "npm run test && npm run test:e2e",
    "isds-test": "node scripts/isds-test.js"
  },
  "build": {
    "appId": "com.lexiseditor.app",
    "directories": {
      "output": "dist"
    },
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        "zip",
        "dmg"
      ]
    },
    "dmg": {
      "background": "build/background.png",
      "iconSize": 128,
      "contents": [
        {
          "x": 180,
          "y": 200,
          "type": "file"
        },
        {
          "x": 420,
          "y": 200,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "LexisEditor"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "Zdenekdi",
        "repo": "LexisEditor"
      }
    ]
  },
  "author": "Advokátní kancelář",
  "license": "ISC",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "electron": "^42.0.1",
    "electron-builder": "^26.8.1",
    "eslint": "^10.4.1",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "jsdom": "^29.1.1",
    "playwright": "^1.60.0"
  },
  "dependencies": {
    "electron-updater": "^6.1.7",
    "html-to-docx": "^1.8.0",
    "node-forge": "^1.3.1",
    "pdf-parse": "^1.1.1"
  },
  "keywords": [],
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/Zdenekdi/LexisEditor/issues"
  },
  "homepage": "https://github.com/Zdenekdi/LexisEditor#readme"
}
