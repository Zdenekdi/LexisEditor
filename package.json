{
  "name": "lexiseditor",
  "productName": "LexisEditor",
  "version": "1.9.2",
  "repository": {
    "type": "git",
    "url": "https://github.com/Zdenekdi/LexisEditor.git"
  },
  "description": "LexisEditor: AI-native náhrada MS Word pro advokáty. Stabilní právnické číslování, automatická anonymizace a hluboká integrace lokální AI (Ollama). Práce se strukturovanými daty pro přesnou rešerši a stylizaci dokumentů. Soukromí na prvním místě, 100% offline běh. Profesionální legal-tech pro Windows, Mac i Linux.",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "npm version patch --no-git-tag-version && electron-builder",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "build": {
    "appId": "com.lexiseditor.app",
    "directories": {
      "output": "dist"
    },
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        "zip",
        "dmg"
      ]
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "LexisEditor"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "Zdenekdi",
        "repo": "LexisEditor"
      }
    ]
  },
  "author": "Advokátní kancelář",
  "license": "ISC",
  "devDependencies": {
    "electron": "^42.0.1",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "electron-updater": "^6.1.7",
    "html-to-docx": "^1.8.0"
  }
}
